---
import { EducationPanel } from './EducationPanel'
import type { EducationDataRow } from '@/lib/parquet'

interface Props {
  title: string
  text: string
  data?: EducationDataRow[]
  csvPath?: string
}

const { title, text, data, csvPath } = Astro.props
---

<div class="flex flex-col gap-2">
  <h1 class="text-3xl font-bold my-6">{title}</h1>
  <p class="text-gray-700">{text}</p>
  {data && <EducationPanel data={data} csvPath={csvPath} client:load />}
</div>
