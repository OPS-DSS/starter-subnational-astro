---
import { MaternalMortalityPanel } from './MaternalMortalityPanel'

type MaternalMortalityDataRow = {
  anio: number
  territorio: string
  sexo: string
  valor: number
}
type GapsChartPoint = {
  anio: number
  brechaHuila?: number
  brechaNacional?: number
  brechaSuaza?: number
  razonHuila?: number
  razonNacional?: number
  razonSuaza?: number
}

interface Props {
  title: string
  text: string
  data: MaternalMortalityDataRow[] | undefined
  gapsData?: GapsChartPoint[]
  csvPath?: string
  gapsCsvPath?: string
}

const { title, text, data, gapsData = [], csvPath, gapsCsvPath } = Astro.props
---

<div class="flex flex-col gap-2">
  <h1 class="text-3xl font-bold my-6">{title}</h1>
  <p class="text-gray-700">{text}</p>
  {
    data && (
      <MaternalMortalityPanel
        data={data}
        gapsData={gapsData}
        csvPath={csvPath}
        gapsCsvPath={gapsCsvPath}
        client:load
      />
    )
  }
</div>
