---
import { AnalyticsPanel } from './AnalyticsPanel'
import type {
  ForestPlotDataRow,
  AnalyticsMaternalRow,
  ScatterMaternalRow,
} from '@/lib/parquet'
import type { EducationIndicator } from '@/lib/parquet'
import { MunicipalitiesMapPanel } from './MunicipalitiesMapPanel'

interface Props {
  title: string
  text: string
  forestPlotData?: ForestPlotDataRow[]
  analyticsMaternalData?: AnalyticsMaternalRow[]
  scatterMaternalData?: ScatterMaternalRow[]
  csvPath?: string
  geojsonUrls: Record<EducationIndicator, string>
  maternalGeojsonUrl?: string
  csvUrl?: string
}

const {
  title,
  text,
  forestPlotData,
  analyticsMaternalData,
  scatterMaternalData,
  csvPath,
  geojsonUrls,
  maternalGeojsonUrl,
  csvUrl,
} = Astro.props
---

<div class="flex flex-col gap-2">
  <h1 class="text-3xl font-bold my-6">{title}</h1>
  <p class="text-gray-700">{text}</p>
  <AnalyticsPanel
    forestPlotData={forestPlotData}
    analyticsMaternalData={analyticsMaternalData}
    scatterMaternalData={scatterMaternalData}
    csvPath={csvPath}
    client:load
  />
  <h2 class="text-3xl font-bold my-6">Mapa de Municipios</h2>
  <MunicipalitiesMapPanel
    geojsonUrls={geojsonUrls}
    maternalGeojsonUrl={maternalGeojsonUrl}
    csvUrl={csvUrl}
    client:only="react"
  />
</div>
